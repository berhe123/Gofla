# ============================================================
# Gofla — Environment Configuration (copy to .env)
# ============================================================

# ---- Shared ----
NODE_ENV=development
APP_NAME=Gofla
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# ---- Database (PostgreSQL + pgvector) ----
POSTGRES_USER=gofla
POSTGRES_PASSWORD=gofla_dev_password
POSTGRES_DB=gofla
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gofla:gofla_dev_password@localhost:5432/gofla?schema=public

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret_dev_only
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_refresh_secret_dev_only
JWT_REFRESH_TTL=7d

# ---- Object Storage (MinIO / S3) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=gofla
S3_SECRET_KEY=gofla_dev_password
S3_BUCKET=gofla-products
S3_PUBLIC_URL=http://localhost:9000/gofla-products
S3_FORCE_PATH_STYLE=true

# ---- Mail (Mailhog in dev) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Gofla <no-reply@gofla.com>"

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# ---- Commerce defaults ----
DEFAULT_CURRENCY=USD
SHIPPING_FLAT_FEE=5
FREE_SHIPPING_THRESHOLD=60
TAX_RATE=0.10
RETURN_WINDOW_DAYS=30
REVIEW_MODERATION=true

# ---- Seed admin ----
SEED_ADMIN_EMAIL=admin@gofla.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_IMAGES_PATH=C:/Users/berhe/Downloads/E-Commerce-main/E-Commerce-main/Images

# ---- Frontend (Vite, prefixed VITE_) ----
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
VITE_APP_NAME=Gofla
